# ── Required ───────────────────────────────────────────────────────────
# Postgres connection string. Supabase or any Postgres with the pgvector
# extension. On hosted Postgres, append ?sslmode=require.
DATABASE_URL=

# Supabase project — used for authentication.
# (NEXT_PUBLIC_SUPABASE_ANON_KEY is also accepted as an alias for the key.)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Resume parsing + resume/company embeddings (pgvector similarity search),
# and the default LLM scoring provider. At least one AI key is required.
OPENAI_API_KEY=

# Encrypts user-supplied (BYOK) API keys at rest.
# Use 64 hex chars or a base64-encoded 32-byte value.
ENCRYPTION_KEY=

# ── Local development ──────────────────────────────────────────────────
# Local preview auth bypass. NEVER enable in production.
TEST_MODE=false
NEXT_PUBLIC_TEST_MODE=false

# Public base URL. In production on Render, RENDER_EXTERNAL_URL is used
# automatically if this is unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional ───────────────────────────────────────────────────────────
# Second LLM provider. AI_PROVIDER pins one ("anthropic" | "openai");
# if unset, the app prefers Anthropic, then OpenAI.
ANTHROPIC_API_KEY=
AI_PROVIDER=

# Rate limiting and response caching (Upstash Redis). Recommended.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Optional scoring providers ─────────────────────────────────────────
# The match scorer tries providers in order and falls back to a zero-cost
# rule-based heuristic, so all of these are optional:
#   local fine-tuned server → Hugging Face → Groq → Claude → OpenAI → heuristic
# (Cloudflare Workers AI is used by the free-inference helper.)
MODEL_SERVER_URL=
HF_MODEL_ID=
HF_TOKEN=
GROQ_API_KEY=
CF_ACCOUNT_ID=
CF_API_TOKEN=
