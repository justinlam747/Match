# Required for the Next.js app and API routes
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Optional local preview auth bypass. Never enable in production.
TEST_MODE=false
NEXT_PUBLIC_TEST_MODE=false
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for resume/company embeddings. Also used as an AI fallback provider.
OPENAI_API_KEY=

# Optional AI provider. If omitted, the app checks Anthropic first, then OpenAI.
ANTHROPIC_API_KEY=
AI_PROVIDER=

# Required for encrypting user-supplied API keys and Gmail tokens.
# Use 64 hex chars or a base64-encoded 32-byte value.
ENCRYPTION_KEY=

# Recommended for rate limiting, caching, and Gmail OAuth state.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email sending and Resend webhooks
RESEND_API_KEY=
FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional enrichment/contact providers
APOLLO_API_KEY=
HUNTER_API_KEY=
FIRECRAWL_API_KEY=
GROQ_API_KEY=
MODEL_SERVER_URL=
HF_MODEL_ID=
HF_TOKEN=
CF_ACCOUNT_ID=
CF_API_TOKEN=
