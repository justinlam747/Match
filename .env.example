# ── Required ───────────────────────────────────────────────────────────
# Postgres connection string. Supabase or any Postgres with the pgvector
# extension. On hosted Postgres, append ?sslmode=require.
DATABASE_URL=

# Supabase project — used for authentication.
# (NEXT_PUBLIC_SUPABASE_ANON_KEY is also accepted as an alias for the key.)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# OpenAI is the only LLM provider — used for resume parsing, resume/company
# embeddings (pgvector similarity), and match scoring. Required.
# (Users can also add their own key in Settings; it takes precedence.)
OPENAI_API_KEY=

# Encrypts user-supplied (BYOK) API keys at rest.
# Use 64 hex chars or a base64-encoded 32-byte value.
ENCRYPTION_KEY=

# ── Local development ──────────────────────────────────────────────────
# Local preview auth bypass. NEVER enable in production.
TEST_MODE=false
NEXT_PUBLIC_TEST_MODE=false

# Public base URL. In production on Render, RENDER_EXTERNAL_URL is used
# automatically if this is unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional ───────────────────────────────────────────────────────────
# Rate limiting and response caching (Upstash Redis). Recommended.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
